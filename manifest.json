{
  "manifest_version": 3,
  "name": "CECT-C Chunking Tool",
  "version": "2.2",
  "description": "CECT-C Chunking Tool.",
  "author": "Ritwiz Mulay",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Content Slicer"
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  }
}
